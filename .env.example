# RAG Chatbot - Environment Variables Example
# ============================================================
# This file documents all environment variables. DO NOT edit the
# real .env directly - it is managed by the platform's env-key
# system and regenerated on every deploy.
#
# Copy values here for reference, then set them via the platform.

# --- Application ---
APP_ENV=development
APP_DEBUG=false

# --- LLM (answer generation) ---
# Set via the platform's create_openai_api_key tool.
OPENAI_API_KEY=
OPENAI_BASE_URL=
LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=1024
LLM_TIMEOUT_SECONDS=30

# --- Embeddings ---
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
EMBEDDING_BATCH_SIZE=32

# --- Chunking ---
CHUNK_SIZE=512
CHUNK_OVERLAP=64

# --- Retrieval ---
TOP_K=5
SCORE_THRESHOLD=0.3

# --- OCR ---
OCR_CHAR_THRESHOLD=20
OCR_DPI=300
OCR_LANGUAGE=eng

# --- Paths (defaults point inside the container) ---
DATA_DIR=/workspace/data
PDF_DIR=/workspace/data/pdfs
INDEX_DIR=/workspace/data/index
SAMPLE_DIR=/workspace/data/sample
